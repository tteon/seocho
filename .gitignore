__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
# But the FinDER tutorial bundle's lib/ contains adapter/helper modules
# that must be tracked. Explicit allowlist of file types we ship there.
!examples/finder/lib/
!examples/finder/lib/*.py
!examples/finder/lib/*.md
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Environment variables
.env
.env.local
.env.production
.env.staging

