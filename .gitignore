# Tutorial work directories (LanceDB tables, owlready2 sqlite, JSONL traces,
# DozerDB data, captured spans). Anything under .seocho/ is local state.
.seocho/

# Rust (seocho-core)
seocho-core/target/
seocho-core/Cargo.lock

# Node
node_modules/
.next/
dist/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
# But the FinDER tutorial bundle's lib/ contains adapter/helper modules
# that must be tracked. Explicit allowlist of file types we ship there.
!examples/finder/lib/
!examples/finder/lib/*.py
!examples/finder/lib/*.md
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Environment variables
.env
examples/observability/secrets/
.env.local
.env.production
.env.staging

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Security
*.pem
*.key
*.crt
*.p12
*.jks

# Temporary files
*.tmp
*.temp
temp/
tmp/
.tmp-land-ontology-cli/
.experiment_runs/

# Logs
logs/
*.log
outputs/

# Data & Database
data/
neo4j/data/
!website/src/data/
!website/src/data/**
!tutorials/data/
!tutorials/data/**
neo4j/logs/
.dolt/
.seocho/
*.db
neostore*
*.lock

# Docker volumes and mounts
workspace/
sharepoint/

# Jupyter checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/
examples/.notebook_runs/
traces/

# Generated extraction scratch artifacts
extraction/output/
extraction/prompt_history.json*

# Large exports
kgbuild_export.*

# Local scratch / nested workspaces (do not track)
daemon/
gnnllm/
tteon.github.io/
deacon/
dolt/
runs/

# Local AI/agent tool overlays — personal/private state only.
# Public middleware code should not track editor/agent state directories.
.agents/
.beads/
# .claude/ stays untracked EXCEPT shared project skills (ADR-0113): those are
# version-controlled team tooling, so ignore everything under .claude/ and
# re-include only .claude/skills/.
.claude/*
!.claude/skills/
.githooks/
.jules/
.serena/

# Empty placeholders
examples/untitled.txt

# Per-PR scratch bodies (the actual PR description lives on GitHub)
PR_BODY.md

# root dataset/ is a non-tracked public surface (CLAUDE.md Public Repo Hygiene)
dataset/

# root ontology/ is a non-tracked public surface (CLAUDE.md Public Repo Hygiene)
ontology/
