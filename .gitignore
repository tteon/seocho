# Tutorial work directories (LanceDB tables, owlready2 sqlite, JSONL traces,
# DozerDB data, captured spans). Anything under .seocho/ is local state.
.seocho/

# Rust (seocho-core)
seocho-core/target/
seocho-core/Cargo.lock

# Node
node_modules/
.next/
dist/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

