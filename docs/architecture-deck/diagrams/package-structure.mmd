flowchart TB
    subgraph SDK ["seocho/ — Canonical SDK Engine"]
        direction TB
        ONT["ontology*.py<br/><small>Ontology facade + context +<br/>serialization + artifacts + governance</small>"]
        QRY["query/<br/><small>intent → strategy → cypher →<br/>semantic agents → answer</small>"]
        AGT["agent/<br/><small>factory + context + contracts</small>"]
        IDX["index/<br/><small>pipeline + linker +<br/>extraction engine</small>"]
        STR["store/<br/><small>graph + vector + llm</small>"]
        RUL["rules.py<br/><small>SHACL-like inference</small>"]
        CLI["client.py<br/><small>public SDK facade</small>"]
        SES["session.py<br/><small>context persistence</small>"]
    end

    subgraph RT ["runtime/ — Deployment Shell"]
        direction TB
        SRV["agent_server.py<br/><small>FastAPI transport</small>"]
        SRT["server_runtime.py<br/><small>service composition</small>"]
        MEM["memory_service.py<br/><small>memory-first facade</small>"]
        POL["policy.py<br/><small>authorization</small>"]
        RDY["agent_readiness.py<br/><small>ready/degraded/blocked</small>"]
        ING["runtime_ingest.py<br/><small>raw text ingestion</small>"]
    end

    subgraph EXT ["extraction/ — Compatibility Layer"]
        direction TB
        SHIM["shims + aliases<br/><small>delegates to seocho/* & runtime/*</small>"]
        PIPE["pipeline.py<br/><small>legacy batch</small>"]
    end

    subgraph UI ["evaluation/ — Platform UI"]
        direction TB
        EVSRV["server.py<br/><small>chat backend proxy</small>"]
        EVUI["static/<br/><small>interactive chat UI</small>"]
    end

    RT --> SDK
    EXT -.->|"compatibility"| RT
    EXT -.->|"compatibility"| SDK
    UI --> RT

