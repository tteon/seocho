{
  "@context": {
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "sh": "http://www.w3.org/ns/shacl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "seocho": "https://seocho.dev/ontology/"
  },
  "@id": "seocho:fibo_base",
  "@type": "seocho:Ontology",
  "name": "fibo_base",
  "version": "1.0.0",
  "description": "Standard FIBO: Company, Person, FinancialMetric, Regulation",
  "nodes": {
    "Company": {
      "@type": "seocho:NodeType",
      "description": "Business entity",
      "sameAs": "schema:Organization",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "sector": {
          "type": "string"
        },
        "headquarters": {
          "type": "string"
        }
      }
    },
    "Person": {
      "@type": "seocho:NodeType",
      "description": "Executive or individual",
      "sameAs": "schema:Person",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "title": {
          "type": "string"
        }
      }
    },
    "FinancialMetric": {
      "@type": "seocho:NodeType",
      "description": "Financial figure",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "value": {
          "type": "string"
        },
        "year": {
          "type": "string"
        }
      }
    },
    "Regulation": {
      "@type": "seocho:NodeType",
      "description": "Regulatory standard",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        }
      }
    }
  },
  "relationships": {
    "REPORTED": {
      "source": "Company",
      "target": "FinancialMetric",
      "description": "Reported metric"
    },
    "EMPLOYS": {
      "source": "Company",
      "target": "Person",
      "description": "Employment",
      "cardinality": "ONE_TO_MANY"
    },
    "FOLLOWS": {
      "source": "Company",
      "target": "Regulation",
      "description": "Regulatory compliance"
    }
  }
}