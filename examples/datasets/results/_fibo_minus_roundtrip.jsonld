{
  "@context": {
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "sh": "http://www.w3.org/ns/shacl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "seocho": "https://seocho.dev/ontology/"
  },
  "@id": "seocho:fibo_minus",
  "@type": "seocho:Ontology",
  "name": "fibo_minus",
  "version": "1.0.0",
  "description": "Minimal FIBO: Company + FinancialMetric only",
  "nodes": {
    "Company": {
      "@type": "seocho:NodeType",
      "description": "Business entity",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "sector": {
          "type": "string"
        }
      }
    },
    "FinancialMetric": {
      "@type": "seocho:NodeType",
      "description": "Financial figure",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "value": {
          "type": "string"
        },
        "year": {
          "type": "string"
        }
      }
    }
  },
  "relationships": {
    "REPORTED": {
      "source": "Company",
      "target": "FinancialMetric",
      "description": "Company reported metric"
    }
  }
}