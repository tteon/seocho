{
  "@context": {
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "sh": "http://www.w3.org/ns/shacl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "seocho": "https://seocho.dev/ontology/"
  },
  "@id": "seocho:fibo_plus",
  "@type": "seocho:Ontology",
  "name": "fibo_plus",
  "version": "1.0.0",
  "description": "Expanded FIBO: full entity coverage",
  "nodes": {
    "Company": {
      "@type": "seocho:NodeType",
      "description": "Business entity",
      "sameAs": "schema:Organization",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "sector": {
          "type": "string"
        },
        "headquarters": {
          "type": "string"
        },
        "employees": {
          "type": "integer"
        }
      }
    },
    "Person": {
      "@type": "seocho:NodeType",
      "description": "Executive or individual",
      "sameAs": "schema:Person",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "title": {
          "type": "string"
        }
      }
    },
    "FinancialMetric": {
      "@type": "seocho:NodeType",
      "description": "Financial figure",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "value": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "period": {
          "type": "string"
        }
      }
    },
    "Regulation": {
      "@type": "seocho:NodeType",
      "description": "Regulatory standard or law",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "jurisdiction": {
          "type": "string"
        }
      }
    },
    "Risk": {
      "@type": "seocho:NodeType",
      "description": "Risk factor",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "category": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        }
      }
    },
    "LegalIssue": {
      "@type": "seocho:NodeType",
      "description": "Legal proceeding or claim",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "status": {
          "type": "string"
        },
        "year": {
          "type": "string"
        }
      }
    },
    "Product": {
      "@type": "seocho:NodeType",
      "description": "Product or service",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "category": {
          "type": "string"
        }
      }
    },
    "Event": {
      "@type": "seocho:NodeType",
      "description": "Business event",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "date": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      }
    },
    "AccountingPolicy": {
      "@type": "seocho:NodeType",
      "description": "Accounting standard or policy",
      "properties": {
        "name": {
          "type": "string",
          "unique": true
        },
        "standard": {
          "type": "string"
        }
      }
    }
  },
  "relationships": {
    "REPORTED": {
      "source": "Company",
      "target": "FinancialMetric",
      "description": "Reported metric"
    },
    "EMPLOYS": {
      "source": "Company",
      "target": "Person",
      "description": "Employment",
      "cardinality": "ONE_TO_MANY"
    },
    "FOLLOWS": {
      "source": "Company",
      "target": "Regulation",
      "description": "Regulatory compliance"
    },
    "FACES": {
      "source": "Company",
      "target": "Risk",
      "description": "Risk exposure"
    },
    "INVOLVED_IN": {
      "source": "Company",
      "target": "LegalIssue",
      "description": "Legal involvement"
    },
    "PRODUCES": {
      "source": "Company",
      "target": "Product",
      "description": "Product/service offering"
    },
    "ATTENDED": {
      "source": "Person",
      "target": "Event",
      "description": "Event participation"
    },
    "APPLIES": {
      "source": "Company",
      "target": "AccountingPolicy",
      "description": "Accounting policy adoption"
    }
  }
}