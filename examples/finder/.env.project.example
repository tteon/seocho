# Copy this file to .env in your seocho-{{model_provider}} project root,
# then fill in the placeholders. Read examples/finder/PROJECT_GUIDE.md for
# the rationale behind each field.

# === Identity ===
# Name your project after the model provider you used.
# Examples: seocho-openai, seocho-grok, seocho-kimi, seocho-deepseek, seocho-qwen
SEOCHO_PROJECT_NAME=seocho-openai

# provider/model — controls the LLM seocho uses. The provider half must
# match a key set below.
SEOCHO_LLM=openai/gpt-4o-mini

# === LLM provider key (set ONLY the one matching SEOCHO_LLM) ===
OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=                # for kimi
# XAI_API_KEY=                     # for grok
# DASHSCOPE_API_KEY=               # for qwen

# Tutorial 1 always also needs OPENAI_API_KEY for embeddings, even if your
# LLM provider is something else. Embeddings require OpenAI in seocho today.

# === Author metadata ===
# These four values land on every Opik trace span, every extracted entity's
# `extracted_by` property, and on the project workspace itself. Fill them
# in even for a personal project — they're how you cite your work later.
SEOCHO_AUTHOR_NAME=Your Name
SEOCHO_AUTHOR_EMAIL=you@example.com
SEOCHO_AUTHOR_GITHUB=your-github-handle
SEOCHO_AUTHOR_AFFILIATION=

# === Optional ===
# Free-form note about this run — useful for distinguishing a "baseline"
# run from a "with-prompt-tweaks" run when both write to the same workspace.
SEOCHO_RUN_NOTES=

# === Neo4j (for the local tutorial stack) ===
# Leave these as-is unless you're running against a different DozerDB.
NEO4J_URI=bolt://tutorials-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tutorialspw

# === FinDER dataset ===
# Default points at the synthetic 10-K subset that ships with the bundle.
# Override to run on the real FinDER JSON.
# FINDER_PATH=/workspace/examples/finder/datasets/finder_full.json

# === Tracing (optional) ===
# Without these, Tutorial 4 falls back to JSONL traces at
# .seocho/private_*/traces.jsonl. Pick ONE of the three options below.
#
# --- Option A: Opik cloud (Comet) ---
# Get your key at https://www.comet.com/opik (account settings).
# DO NOT set OPIK_URL — the SDK auto-routes to the cloud API.
# Setting the UI URL (https://www.comet.com/opik) breaks with 405s.
# OPIK_API_KEY=<your-personal-cloud-key>
# OPIK_WORKSPACE=<your-comet-workspace>
# OPIK_PROJECT_NAME=seocho-openai-yourhandle
#
# --- Option B: Self-hosted Opik (`make opik-up`) ---
# Point OPIK_URL_OVERRIDE at YOUR host's API endpoint. Note the /api/
# suffix — without it, requests hit the UI and get 405.
# OPIK_URL_OVERRIDE=http://opik-backend:8080/api/
# OPIK_WORKSPACE=default
# OPIK_PROJECT_NAME=seocho-openai
#
# --- Option C: No tracing (default) ---
# Leave all OPIK_* unset; T4 writes JSONL traces locally.
