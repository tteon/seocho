{
  "uid":"seocho-dependencies","title":"SEOCHO Dependencies","tags":["seocho","dependencies"],"schemaVersion":41,"version":1,"refresh":"15s","time":{"from":"now-1h","to":"now"},
  "panels":[
    {"id":1,"type":"stat","title":"Scrape targets up","gridPos":{"h":5,"w":8,"x":0,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum(up)"}]},
    {"id":2,"type":"stat","title":"PostgreSQL up","gridPos":{"h":5,"w":4,"x":8,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"max(pg_up)"}]},
    {"id":3,"type":"stat","title":"etcd leader","gridPos":{"h":5,"w":4,"x":12,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"min(etcd_server_has_leader)"}]},
    {"id":4,"type":"stat","title":"PostgreSQL deadlocks","gridPos":{"h":5,"w":4,"x":16,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum(increase(pg_stat_database_deadlocks[1h]))"}]},
    {"id":5,"type":"stat","title":"etcd proposal failures","gridPos":{"h":5,"w":4,"x":20,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum(increase(etcd_server_proposals_failed_total[1h]))"}]},
    {"id":6,"type":"timeseries","title":"Database client p95","gridPos":{"h":10,"w":24,"x":0,"y":5},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le, db_system_name, db_operation_name) (rate(db_client_operation_duration_seconds_bucket[5m])))","legendFormat":"{{db_system_name}} {{db_operation_name}}"}]}
  ]
}
