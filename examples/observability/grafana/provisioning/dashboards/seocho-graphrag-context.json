{
  "uid":"seocho-graphrag-context","title":"SEOCHO GraphRAG and Context","tags":["seocho","graphrag","context"],"schemaVersion":41,"version":1,"refresh":"15s","time":{"from":"now-1h","to":"now"},
  "panels":[
    {"id":1,"type":"timeseries","title":"Retrieval p95","gridPos":{"h":8,"w":12,"x":0,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le, source, outcome) (rate(seocho_retrieval_duration_seconds_bucket[5m])))","legendFormat":"{{source}} {{outcome}}"}]},
    {"id":2,"type":"timeseries","title":"Text2Cypher p95","gridPos":{"h":8,"w":12,"x":12,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le, stage, outcome) (rate(seocho_text2cypher_duration_seconds_bucket[5m])))","legendFormat":"{{stage}} {{outcome}}"}]},
    {"id":3,"type":"timeseries","title":"Context candidate vs selected tokens","gridPos":{"h":8,"w":24,"x":0,"y":8},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (strategy) (rate(seocho_context_candidate_token_count_tokens_sum[5m]))","legendFormat":"candidate {{strategy}}"},{"refId":"B","expr":"sum by (strategy) (rate(seocho_context_selected_token_count_tokens_sum[5m]))","legendFormat":"selected {{strategy}}"}]},
    {"id":4,"type":"timeseries","title":"Retrieval throughput and inflight","gridPos":{"h":8,"w":12,"x":0,"y":16},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (source) (rate(seocho_retrieval_duration_seconds_count[5m]))","legendFormat":"QPS {{source}}"},{"refId":"B","expr":"sum by (source) (seocho_retrieval_inflight)","legendFormat":"inflight {{source}}"}]},
    {"id":5,"type":"timeseries","title":"Retrieval admission rejections","gridPos":{"h":8,"w":12,"x":12,"y":16},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (source, reason) (rate(seocho_retrieval_admission_rejection_count_total[5m]))","legendFormat":"{{source}} {{reason}}"}]},
    {"id":6,"type":"timeseries","title":"Plan audit speedup","gridPos":{"h":8,"w":12,"x":0,"y":24},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (cohort) (seocho_query_plan_speedup_sum) / clamp_min(sum by (cohort) (seocho_query_plan_speedup_count), 1)","legendFormat":"{{cohort}}"}]},
    {"id":7,"type":"timeseries","title":"Plan findings baseline vs candidate","gridPos":{"h":8,"w":12,"x":12,"y":24},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (variant, finding) (seocho_query_plan_finding_count_total)","legendFormat":"{{variant}} {{finding}}"}]}
  ]
}
