{
  "uid":"seocho-memory-consistency","title":"SEOCHO Memory Consistency","tags":["seocho","memory"],"schemaVersion":41,"version":1,"refresh":"15s","time":{"from":"now-1h","to":"now"},
  "panels":[
    {"id":1,"type":"stat","title":"Projection lag events","gridPos":{"h":5,"w":6,"x":0,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"max(seocho:projection_lag_events)"}]},
    {"id":2,"type":"stat","title":"Pending outbox","gridPos":{"h":5,"w":6,"x":6,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum(seocho_projection_outbox_pending_entries)"}]},
    {"id":3,"type":"stat","title":"Oldest pending age","gridPos":{"h":5,"w":6,"x":12,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"max(seocho_projection_outbox_oldest_age_seconds)"}]},
    {"id":4,"type":"timeseries","title":"Memory commit and projection batch p95","gridPos":{"h":10,"w":24,"x":0,"y":5},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le, outcome) (rate(seocho_memory_commit_duration_seconds_bucket[5m])))","legendFormat":"commit {{outcome}}"},{"refId":"B","expr":"histogram_quantile(0.95, sum by (le, projection, outcome) (rate(seocho_projection_batch_duration_seconds_bucket[5m])))","legendFormat":"project {{projection}} {{outcome}}"}]},
    {"id":5,"type":"timeseries","title":"Authoritative memory commit phase p95","gridPos":{"h":10,"w":24,"x":0,"y":15},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le, phase, outcome) (rate(seocho_memory_commit_phase_duration_milliseconds_bucket[5m])))","legendFormat":"{{phase}} {{outcome}}"}]},
    {"id":6,"type":"timeseries","title":"PostgreSQL workload admission","gridPos":{"h":8,"w":12,"x":0,"y":25},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (tier, outcome) (rate(seocho_postgres_admission_count_total[5m]))","legendFormat":"{{tier}} {{outcome}}"}]},
    {"id":7,"type":"timeseries","title":"PostgreSQL admission wait p95","gridPos":{"h":8,"w":12,"x":12,"y":25},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le, tier, outcome) (rate(seocho_postgres_admission_wait_seconds_bucket[5m])))","legendFormat":"{{tier}} {{outcome}}"}]},
    {"id":8,"type":"timeseries","title":"Single-flight cache outcomes","gridPos":{"h":8,"w":12,"x":0,"y":33},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (outcome) (rate(seocho_postgres_cache_request_count_total[5m]))","legendFormat":"{{outcome}}"}]},
    {"id":9,"type":"timeseries","title":"Freshness-aware PostgreSQL routes","gridPos":{"h":8,"w":12,"x":12,"y":33},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"refId":"A","expr":"sum by (role, reason) (rate(seocho_postgres_route_count_total[5m]))","legendFormat":"{{role}} {{reason}}"}]}
  ]
}
