# teaching-resource/.env.example
# Copy to .env in this directory (or the repo root) and fill in.
# Notebooks load this via python-dotenv on the first cell.

# ─────────────────────────────────────────────────────────────────────────────
# LLM Providers — at least OPENAI_API_KEY is required; the others are
# strongly recommended so the "compare 4 providers" cells light up fully.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                       # https://platform.openai.com
MOONSHOT_API_KEY=                           # Kimi K2.5 (https://platform.moonshot.ai)
DEEPSEEK_API_KEY=                           # https://platform.deepseek.com
XAI_API_KEY=                                # Grok (https://x.ai)

# ─────────────────────────────────────────────────────────────────────────────
# Opik — workspace 'seocho' is shared by invited members; OPIK_USER identifies
# you so the auto-generated project name is unique per member.
#   Project naming default: teaching-ch{N}-{OPIK_USER}
#   Override entirely:      TEACHING_OPIK_PROJECT=my-project
# ─────────────────────────────────────────────────────────────────────────────
OPIK_API_KEY=                               # required for hosted Opik
OPIK_WORKSPACE=seocho
OPIK_USER=                                  # e.g. hardy, jisoo — required for per-member projects
# TEACHING_OPIK_PROJECT=                    # uncomment to override the default name

# ─────────────────────────────────────────────────────────────────────────────
# Neo4j / DozerDB — required for Ch 1, 2 (graph indexing + GDS).
# Ch 3, 4 can run partial demos without it. Ch 5 doesn't need it.
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: dataset cache and tracing knobs
# ─────────────────────────────────────────────────────────────────────────────
# FINDER_HF_REPO=Linq-AI-Research/FinanceRAG
# FINDER_HF_SUBSET=FinDER
# FINDER_HF_SPLIT=test
# FINDER_CACHE_DIR=./data

# SEOCHO_TRACE_BACKEND=opik                  # opik | jsonl | console | none
# SEOCHO_TRACE_JSONL_PATH=./traces/seocho.jsonl
